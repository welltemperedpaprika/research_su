$molecule
read
$end

$rem

jobtype sp
method ccsd(T)
xc_grid 000099000590
basis aug-cc-pcVTZ
max_scf_cycles 200
thresh 14
scf_convergence 8
mem_total 64000
mem_static 1500
symmetry false
sym_ignore true
scf_guess read
unrestricted true
scf_algorithm gdm
$end

$multipole_field
ZZ 0.0001
$end

