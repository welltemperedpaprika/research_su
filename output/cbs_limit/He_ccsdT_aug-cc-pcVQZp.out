jobtype sp
method CCSD(T)
xc_grid 000099000590
basis aug-cc-pcVQZ
max_scf_cycles 200
thresh 14
scf_convergence 8
scf_algorithm gdm
symmetry false
sym_ignore true
unrestricted true
gen_scfman true
internal_stability_iter 15
internal_stability_davidson_iter 200
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
n_frozen_core 0
$end


