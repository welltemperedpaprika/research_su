thresh 14
scf_convergence 8
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
symmetry false
sym_ignore true
scf_guess read
unrestricted true
scf_algorithm gdm
n_frozen_core 0
$end

$multipole_field
ZZ 0.0001
$end


