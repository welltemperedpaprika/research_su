scf_algorithm gdm
symmetry false
sym_ignore true
unrestricted false
gen_scfman false
internal_stability_iter 15
internal_stability_davidson_iter 200
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
n_frozen_core 1000
$end

