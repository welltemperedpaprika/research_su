read
$end

$rem

jobtype sp
exchange wb97m(2)
xc_grid 000099000590
basis aug-cc-pcVTZ
max_scf_cycles 200
thresh 14
scf_convergence 8
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
symmetry false
sym_ignore true
scf_guess read
unrestricted false
scf_algorithm gdm
n_frozen_core 0
$end

$multipole_field
Z -0.0001
$end


