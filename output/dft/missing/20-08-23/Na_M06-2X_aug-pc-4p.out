0 2
Na
$end

$rem
jobtype sp
method M06-2X
xc_grid 000099000590
basis aug-pc-4
max_scf_cycles 500
thresh 14
scf_convergence 6
scf_algorithm gdm_qls
symmetry false
sym_ignore true
unrestricted true
gen_scfman true
internal_stability_iter 15
internal_stability_davidson_iter 200
mem_total 64000
mem_static 1500
n_frozen_core 0
$end


