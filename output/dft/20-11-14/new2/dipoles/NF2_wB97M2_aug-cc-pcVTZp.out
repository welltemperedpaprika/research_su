cc_memory 96000
cc_backend xm
mem_static 1500
symmetry false
sym_ignore true
scf_guess read
unrestricted false
scf_algorithm gdm
n_frozen_core 0
gen_scfman true
$end

$multipole_field
Z -0.0001
$end



