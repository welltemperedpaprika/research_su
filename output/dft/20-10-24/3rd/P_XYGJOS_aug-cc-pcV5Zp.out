User input:
--------------------------------------------------------------
$molecule
0 4
P
$end

$rem
jobtype sp
exchange XYGJOS
xc_grid 000099000590
basis aug-cc-pcV5Z
aux_basis rimp2-aug-cc-pVQZ
max_scf_cycles 200
thresh 14
scf_convergence 8
scf_algorithm gdm
symmetry false
sym_ignore true
unrestricted false
gen_scfman false
internal_stability_iter 15
internal_stability_davidson_iter 200
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
n_frozen_core 1000
$end



