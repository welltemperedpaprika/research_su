0 3
O1	0.0000	0.0000	0.0000
O2	0.0000	0.0000	1.2075
$end

$rem
jobtype sp
exchange XYGJOS
xc_grid 000099000590
basis aug-cc-pcVTZ
aux_basis rimp2-aug-cc-pVTZ
max_scf_cycles 200
thresh 14
scf_convergence 8
scf_algorithm gdm
symmetry false
sym_ignore true
unrestricted false
gen_scfman false
internal_stability_iter 15
internal_stability_davidson_iter 200
mem_total 128000
cc_memory 96000
cc_backend xm
mem_static 1500
n_frozen_core 0
$end



